[general]
abbreviate-tab-names=false
compat-delete='delete-sequence'
default-shell='/usr/bin/fish'
display-n=0
display-tab-names=0
gtk-prefer-dark-theme=true
gtk-theme-name='Flat-Remix-GTK-Orange-Dark'
gtk-use-system-default-theme=true
hide-tabs-if-one-tab=false
history-size=1000
infinite-history=true
max-tab-name-length=100
mouse-display=true
open-tab-cwd=true
prompt-on-close-tab=1
prompt-on-quit=true
quick-open-command-line='gedit %(file_path)s'
restore-tabs-notify=true
restore-tabs-startup=true
save-tabs-when-changed=true
scroll-keystroke=true
scroll-output=true
start-at-login=true
tab-close-buttons=true
use-default-font=true
use-popup=false
use-scrollbar=true
use-trayicon=false
window-halignment=0
window-height=66
window-losefocus=true
window-refocus=false
window-tabbar=false
window-vertical-displacement=0
window-width=100

[keybindings/global]
show-hide='grave'

[keybindings/local]
clipboard-paste='<Primary>v'
close-tab='<Primary>w'
close-terminal='<Alt>x'
focus-terminal-down='<Alt>j'
focus-terminal-left='<Alt>h'
focus-terminal-right='<Alt>l'
focus-terminal-up='<Alt>k'
move-terminal-split-down='<Primary><Shift><Alt>j'
move-terminal-split-left='<Primary><Shift><Alt>h'
move-terminal-split-right='<Primary><Shift><Alt>l'
move-terminal-split-up='<Primary><Shift><Alt>k'
new-tab='<Primary>t'
new-tab-home='<Primary>h'
next-tab='disabled'
previous-tab='disabled'
reset-terminal='<Primary>F5'
search-terminal='<Primary>f'
split-tab-horizontal='<Shift><Alt>j'
split-tab-vertical='<Shift><Alt>l'
switch-tab1='<Primary>1'
switch-tab10='<Primary>0'
switch-tab2='<Primary>2'
switch-tab3='<Primary>3'
switch-tab4='<Primary>4'
switch-tab5='<Primary>5'
switch-tab6='<Primary>6'
switch-tab7='<Primary>7'
switch-tab8='<Primary>8'
switch-tab9='<Primary>9'
toggle-fullscreen='F11'

[style/background]
transparency=71

[style/font]
allow-bold=true
palette='#222222222222:#FFFF00000F0F:#8C8CE0E00A0A:#FFFFB9B90000:#00008D8DF8F8:#6C6C4343A5A5:#0000D7D7EBEB:#FFFFFFFFFFFF:#444444444444:#FFFF27273F3F:#ABABE0E05A5A:#FFFFD1D14141:#00009292FFFF:#9A9A5F5FEBEB:#6767FFFFEFEF:#FFFFFFFFFFFF:#FFFFFAFAF3F3:#0D0D0F0F1818'
palette-name='Argonaut'
